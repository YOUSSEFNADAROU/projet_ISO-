# Configuration Backend - ISO Audit Application

# ==================== MONGODB ====================
# Connection string pour MongoDB
# Local MongoDB: mongodb://localhost:27017/iso-audit
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb://localhost:27017/iso-audit

# ==================== OPENAI API (OPTIONNEL) ====================
# Clé API OpenAI pour intégration ChatGPT
# Obtenir depuis: https://platform.openai.com/api/keys
# Format: sk-proj-... ou sk-...
# IMPORTANT: Ne jamais committer cette clé!
# Si vide: mode offline (local expert seulement)
OPENAI_API_KEY=

# Modèle OpenAI à utiliser
OPENAI_MODEL=gpt-4-turbo
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo

# Timeout pour appels OpenAI (millisecondes)
OPENAI_TIMEOUT=30000

# ==================== SERVER ====================
# Port du serveur backend
PORT=5000

# Node environment
NODE_ENV=development

# ==================== LOGGING ====================
# Niveau de logs
LOG_LEVEL=info

# ==================== SESSION ====================
# Secret pour sessions
SESSION_SECRET=your-super-secret-key-change-this-in-production

# ==================== CORS ====================
# URL du frontend pour CORS
FRONTEND_URL=http://localhost:5175

# ==================== EMAIL (FUTUR) ====================
# Configuration email pour notifications
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@iso-audit.com

# ==================== EXTERNAL APIs ====================
# Clés API externes (si nécessaire)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ==================== NOTES ====================
# Mode OFFLINE (recommandé pour départ):
#   - Laisser OPENAI_API_KEY vide
#   - Chatbot fonctionne 100% avec base locale
#   - Aucun coût
#
# Mode HYBRID (recommandé pour production):
#   - Ajouter OPENAI_API_KEY=sk-...
#   - Local expert + ChatGPT escalade
#   - ~$0.01-0.05 par question complexe
#
# Mode ONLINE (AI only):
#   - Utiliser uniquement OpenAI
#   - Coûts plus élevés
